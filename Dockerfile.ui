FROM python:3.11-slim

# Set non-interactive environment
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Install minimal dependencies for Streamlit
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install only streamlit and httpx (for API calls)
RUN pip install --no-cache-dir streamlit httpx requests pillow

# Set working directory
WORKDIR /app

# Copy only the streamlit frontend code
COPY drone_localization/streamlit ./streamlit

# Expose Streamlit port
EXPOSE 8501

# Run Streamlit
CMD ["streamlit", "run", "streamlit/app.py", "--server.address=0.0.0.0", "--server.port=8501"]