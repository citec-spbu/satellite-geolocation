{
  "model": {
    "backbone": {
      "type": "ViT-S",
      "pretrain": false,
      "output_index": [0]
    },
    "neck": {
      "type": "CCN",
      "output_dims": 128,
      "UAV_output_index": [0],
      "Satellite_ouput_index": 0
    },
    "head": {
        "type":"AttentionFusionLib",
        "fusion_type": "CAT_SA",
        "head_pool":"linear",
        "dropout_rate": 0.1,
        "input_ndim": 128,
        "mid_ndim": 256,
        "attention_layer_num":4,
        "linear_layer_num": 1,
        "enable_position_embedding": true,
        "pos_lenght": [128,383]

    },
    "postprocess": {
      "upsample_to_original": true,
      "upsample_method": "NearstUpsample",
      "output_size": [576, 576]
    },
    "loss": {
      "cls_loss": {
        "type": "BalanceLoss",
        "center_R": 31,
        "neg_weight": 130
      },
      "loc_loss":{
        "type": "LocSmoothL1Loss",
        "topk": 1,
        "weight_rate": 1.0
      }
    }
  },
  "data_config": {
    "batchsize": 8,
    "num_worker": 16,
    "val_batchsize": 8,
    "train_dir": "map2019/train",
    "val_dir": "map2019/val",
    "test_dir": "map2019/train",
    "test_mode": "merge_test_700-1800_cr0.95_stride100",
    "UAVhw": [128, 128],
    "Satellitehw": [384, 384]
  },
  "pipline_config": {
    "train_pipeline": {
      "UAV": {
        "RandomErasing": {
          "probability": 0.3
        },
        "RandomResize": {
          "img_size": [128, 128]
        },
        "ToTensor": {}
      },
      "Satellite": {
        "RandomCrop": {
          "cover_rate": 0.85,
          "map_size": [512, 1000]
        },
        "RandomResize": {
          "img_size": [384, 384]
        },
        "ToTensor": {}
      }
    }
  },
  "lr_config": {
    "lr": 0.00005,
    "type": "cosine",
    "warmup_iters": 500,
    "warmup_ratio": 0.01
  },
  "train_config": {
    "autocast": true,
    "num_epochs": 30
  },
  "test_config": {
    "num_worker": 16,
    "filterR": 51,
    "checkpoint": "checkpoints/test/output/net_001.pth"
  },
  "checkpoint_config": {
    "interval": 1,
    "epoch_start_save": 0,
    "only_save_best": false
  },
  "download_from": ""
}