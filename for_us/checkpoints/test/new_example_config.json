{
  "model": {
    "backbone": {
      "type": "CvT",
      "vit_type": "cvt13",
      "pretrain_path": "",
      "pretrain": true,
      "output_index": [0, 1, 2]
    },
    "neck": {
      "type": "CCN",
      "output_dims": 128,
      "UAV_output_index": [0],
      "Satellite_ouput_index": 0
    },
    "head": {
      "type":"ChannelEmbedding", 
      "input_ndim": 128, 
      "mid_process_channels":[64, 16, 1]

    },
    "postprocess": {
      "upsample_to_original": true,
      "upsample_method": "NearstUpsample",
      "output_size": [576, 576]
    },
    "loss": {
      "cls_loss": {
        "type": "BalanceLoss",
        "center_R": 31,
        "neg_weight": 130
      }
    }
  },
  "data_config": {
    "batchsize": 8,
    "num_worker": 8,
    "val_batchsize": 8,
    "train_dir": "map2019/train",
    "val_dir": "map2019/val",
    "test_dir": "map2019/train",
    "test_mode": "merge_test_700-1800_cr0.95_stride100",
    "UAVhw": [192, 192],
    "Satellitehw": [576, 576]
  },
  "pipline_config": {
    "train_pipeline": {
      "UAV": {
        "RandomErasing": {
          "probability": 0.3
        },
        "RandomResize": {
          "img_size": [192, 192]
        },
        "ToTensor": {}
      },
      "Satellite": {
        "RandomCrop": {
          "cover_rate": 0.85,
          "map_size": [512, 1000]
        },
        "RandomResize": {
          "img_size": [576, 576]
        },
        "ToTensor": {}
      }
    }
  },
  "lr_config": {
    "lr": 0.00015,
    "type": "cosine",
    "warmup_iters": 500,
    "warmup_ratio": 0.01
  },
  "train_config": {
    "autocast": true,
    "num_epochs": 12
  },
  "test_config": {
    "num_worker": 8,
    "filterR": 51,
    "checkpoint": "checkpoints/test/output/net_001.pth"
  },
  "checkpoint_config": {
    "interval": 1,
    "epoch_start_save": 0,
    "only_save_best": false
  },
  "download_from": "checkpoints/CvT-13-384x384-IN-22k.pth"
}